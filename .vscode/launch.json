// .vscode/launch.json
{
    "version": "0.2.0",
    "configurations": [
        {
            "name"          : "Debug STM32 (OpenOCD)",
            "type"          : "cortex-debug",
            "request"       : "launch",
            "servertype"    : "openocd",
            "executable"    : "${workspaceFolder}/build/stm32-nucleo-cicd",
            "configFiles"   : [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "svdFile"       : "${workspaceFolder}/STM32F401.svd",
            "runToEntryPoint": "main",
            "preLaunchTask" : "CMake Build",
            "showDevDebugOutput": "none",
            "openOCDLaunchCommands": [
                "adapter speed 2000"
            ]
        }
    ]
}
